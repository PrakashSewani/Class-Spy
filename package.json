{
  "name": "class-spy",
  "displayName": "Class Spy",
  "description": "Instantly reveal CSS definitions and decoded Tailwind styles by hovering over class attributes in HTML, React, Vue, Svelte, Astro, and Angular.",
  "icon": "images/icon.png",
  "version": "0.0.5",
  "publisher": "PrakashSewani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrakashSewani/Class-Spy.git"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/PrakashSewani"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "css",
    "tailwind",
    "hover",
    "class",
    "className",
    "html",
    "react",
    "vue",
    "svelte",
    "astro",
    "angular",
    "scss",
    "less"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:sass",
    "onLanguage:less"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "classSpy.openFile",
        "title": "Class Spy: Open CSS Definition File"
      },
      {
        "command": "classSpy.editStyle",
        "title": "Class Spy: Edit CSS Rule"
      },
      {
        "command": "classSpy.refreshIndex",
        "title": "Class Spy: Refresh CSS Class Index",
        "icon": "$(refresh)"
      },
      {
        "command": "classSpy.showUsages",
        "title": "Class Spy: Show All Usages"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.57.1",
    "glob": "^13.0.6",
    "mocha": "^10.8.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "postcss": "^8.4.32",
    "postcss-less": "^6.0.0",
    "postcss-sass": "^0.5.0",
    "postcss-scss": "^4.0.9"
  }
}
